<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ newsletter_name }} - {{ date }}</title>
</head>
<body style="margin:0;padding:0;background:#f1f5f9;font-family:-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:#0f172a;">
  <div style="max-width:640px;margin:0 auto;padding:24px 16px;">

    <!-- Header -->
    <div style="text-align:center;padding:8px 0 20px;">
      <div style="font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:#0284c7;font-weight:700;">{{ newsletter_name }}</div>
      <div style="font-size:14px;color:#64748b;margin-top:4px;">{{ tagline }} &middot; {{ date }}</div>
    </div>

    <div style="background:#ffffff;border-radius:14px;padding:8px 22px 22px;box-shadow:0 1px 4px rgba(0,0,0,.06);">

      <p style="font-size:15px;color:#334155;">Good morning! Here is your research digest{% if topic_sections %} across {{ topic_sections|length }} topic{{ 's' if topic_sections|length != 1 }}{% endif %}.</p>

      {% for section in topic_sections %}
      <h2 style="font-size:18px;margin:26px 0 6px;color:#0f172a;border-bottom:2px solid #e2e8f0;padding-bottom:6px;">{{ section.label }}</h2>
      {% for paper in section.papers %}
      <div style="padding:14px 0;border-bottom:1px solid #f1f5f9;">
        <a href="{{ paper.url }}" style="font-size:16px;font-weight:600;color:#0369a1;text-decoration:none;">{{ paper.title }}</a>
        <div style="font-size:12px;color:#94a3b8;margin:4px 0 8px;">
          {{ paper.source }}{% if paper.venue_line() %} &middot; {{ paper.venue_line() }}{% endif %}{% if paper.author_line() %} &middot; {{ paper.author_line() }}{% endif %}{% if paper.citations %} &middot; {{ paper.citations }} citations{% endif %}
        </div>
        <div style="font-size:14px;color:#334155;line-height:1.5;">{{ paper.summary }}</div>
      </div>
      {% endfor %}
      {% else %}
      <p style="font-size:14px;color:#64748b;">No new papers matched your topics today. We'll keep watching.</p>
      {% endfor %}

      {% if news %}
      <h2 style="font-size:18px;margin:30px 0 6px;color:#0f172a;border-bottom:2px solid #e2e8f0;padding-bottom:6px;">What's happening in research</h2>
      {% for item in news %}
      <div style="padding:10px 0;border-bottom:1px solid #f1f5f9;">
        <a href="{{ item.url }}" style="font-size:15px;font-weight:600;color:#0369a1;text-decoration:none;">{{ item.title }}</a>
        <div style="font-size:12px;color:#94a3b8;margin-top:3px;">{{ item.source }}</div>
        {% if item.summary %}<div style="font-size:13px;color:#475569;margin-top:5px;">{{ item.summary }}</div>{% endif %}
      </div>
      {% endfor %}
      {% endif %}

    </div>

    <!-- Footer -->
    <div style="text-align:center;padding:20px 8px;font-size:12px;color:#94a3b8;line-height:1.6;">
      You receive this because you subscribed to {{ newsletter_name }}.<br/>
      {% if unsubscribe_url %}<a href="{{ unsubscribe_url }}" style="color:#0284c7;">Unsubscribe</a> &middot; {% endif %}
      <a href="{{ site_url or '#' }}" style="color:#0284c7;">Manage topics</a><br/>
      Open-source &middot; built with ResearchPulse
    </div>

  </div>
</body>
</html>

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Packaging / build
build/
dist/
*.egg-info/
.eggs/
*.egg
*.whl
pip-wheel-metadata/
*.manifest
*.spec

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml

# ── Virtual environments ──────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Secrets (never commit) ────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Runtime data (local agent / previews) ─────────────────────────────────
# User preferences, reading memory, and dedup cache are created at runtime.
# Newsletter hosts: GitHub Actions force-adds data/seen.json after each run
# (see .github/workflows/daily.yml).
preview/
*.local.html
data/local.json
data/memory.json
data/seen.json

# Keep an empty seed so `data/` exists in fresh clones (optional reference)
!data/seen.json.example

# Pip-install user data if created inside the repo during dev
.research-pulse/

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE / editor ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# ── OS junk ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Node (if present) ─────────────────────────────────────────────────────
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Nested / unrelated projects in this workspace ─────────────────────────

# ResearchPulse configuration (copy to .env for local runs)
# All values here are also settable as GitHub Actions Secrets for the hosted run.

# --- Subscriber database -------------------------------------------------
# Published-to-web CSV URL of your Google Sheet (File > Share > Publish to web > CSV).
# Leave blank to use config/subscribers.sample.csv for local testing.
SUBSCRIBERS_CSV_URL=

# --- Email sending (Brevo free tier: 300 emails/day) ---------------------
# Create a free Brevo account, then SMTP & API > SMTP for these values.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_KEY=
# The verified sender address and display name shown to recipients.
SENDER_EMAIL=
SENDER_NAME=ResearchPulse

# Base URL for unsubscribe/confirm links. MUST be your Google Apps Script
# web app URL (the one that handles ?action=unsubscribe&token=...).
# e.g. https://script.google.com/macros/s/<your-id>/exec
SITE_URL=

# --- Optional LLM summaries ----------------------------------------------
# If NONE of these are set, ResearchPulse uses the paper's own abstract (zero cost).
# Provide exactly one to enable plain-language TL;DRs.
GROQ_API_KEY=
GEMINI_API_KEY=
# For a local open-source model via Ollama (e.g. `ollama run llama3.2`):
OLLAMA_HOST=
OLLAMA_MODEL=llama3.2

# --- Optional: Semantic Scholar (200M+ papers, all fields) ----------------
# Free key raises rate limits and enables the Semantic Scholar source.
# Without it, ResearchPulse still covers everything via arXiv + OpenAlex +
# Crossref + Europe PMC. Request a key (free):
#   https://www.semanticscholar.org/product/api#api-key-form
S2_API_KEY=
